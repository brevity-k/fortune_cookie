# SECURITY: Generate a SEPARATE key for each project. Do NOT reuse keys across projects.
# If one project is compromised, only that project's key needs rotation.

# Anthropic (https://console.anthropic.com) - for blog/fortune/horoscope auto-generation
# Create a dedicated key named "fortune_cookie" in the Anthropic Console
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Resend (https://resend.com) - for contact form auto-response emails
# Create a dedicated API key named "fortune_cookie" in the Resend dashboard
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email that receives contact form submissions
CONTACT_EMAIL=your-email@example.com
NEXT_PUBLIC_CONTACT_EMAIL=your-email@example.com

# Sender address (use your verified domain, or Resend's default for testing)
FROM_EMAIL=Fortune Cookie <onboarding@resend.dev>

# X (Twitter) API - for automated daily tweets (https://developer.x.com)
X_CONSUMER_KEY=your-consumer-key
X_SECRET_KEY=your-secret-key
X_ACCESS_TOKEN=your-access-token
X_ACCESS_TOKEN_SECRET=your-access-token-secret

# Upstash Redis (https://console.upstash.com) - for API rate limiting
UPSTASH_REDIS_REST_URL=https://xxxxxxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxx

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxx
STRIPE_PRICE_ID=price_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Premium JWT
PREMIUM_JWT_SECRET=your-random-256-bit-secret
